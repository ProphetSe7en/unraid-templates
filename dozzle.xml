<?xml version="1.0"?>
<Container version="2">
  <Name>dozzle</Name>
  <Repository>ghcr.io/prophetse7en/dozzle:latest</Repository>
  <Registry>https://github.com/prophetse7en/dozzle/pkgs/container/dozzle</Registry>
  <Branch>
    <Tag>latest</Tag>
    <TagDescription>Latest upstream Dozzle with healthcheck (rebuilt weekly)</TagDescription>
  </Branch>
  <Network>proxynet</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/ProphetSe7en/dozzle</Support>
  <Project>https://github.com/amir20/dozzle</Project>
  <Overview>Dozzle is a real-time log viewer for Docker containers. This is a thin wrapper over the official image that adds a Docker HEALTHCHECK (built-in healthcheck does not work with Unraid's --health-cmd).</Overview>
  <Category>Tools:Utilities</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <Icon>https://raw.githubusercontent.com/selfhosters/unRAID-CA-templates/master/templates/img/dozzle.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="WebUI" Target="8080" Default="8080" Mode="tcp" Description="Dozzle web interface port" Type="Port" Display="always" Required="false" Mask="false">8080</Config>
  <Config Name="Docker Host" Target="DOCKER_HOST" Default="/var/run/docker.sock" Mode="" Description="Docker socket path or TCP proxy address (e.g. tcp://dockerproxy:2375)" Type="Variable" Display="always" Required="true" Mask="false">/var/run/docker.sock</Config>
  <Config Name="Base URL" Target="DOZZLE_BASE" Default="/" Mode="" Description="Base URL path for reverse proxy setups" Type="Variable" Display="always" Required="false" Mask="false">/</Config>
  <Config Name="Log Level" Target="DOZZLE_LEVEL" Default="info" Mode="" Description="Logging level (debug, info, warn, error)" Type="Variable" Display="always" Required="false" Mask="false">info</Config>
  <Config Name="Disable Analytics" Target="DOZZLE_NO_ANALYTICS" Default="true" Mode="" Description="Disable anonymous usage analytics" Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
</Container>
